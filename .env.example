# Notion public OAuth integration credentials.
# Create at https://www.notion.so/profile/integrations (type: Public).
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
# Must exactly match the redirect URI registered on the integration.
# Local dev: use ngrok or vercel preview, NOT http://localhost.
NOTION_OAUTH_REDIRECT_URI=

# Public base URL of this app (MUST be reachable from Notion's image servers).
# Example: https://gallery-cover.vercel.app
# Leave empty locally — the app will use window.location.origin,
# but Notion can't reach localhost. For real testing use Vercel or ngrok.
NEXT_PUBLIC_APP_URL=
